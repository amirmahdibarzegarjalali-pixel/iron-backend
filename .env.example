# این فایل را کپی کنید به .env و مقادیر واقعی را جایگزین کنید
# cp .env.example .env

PORT=4000
NODE_ENV=production

# رمزهای امضای توکن — حتماً در تولید (production) عوض کنید (یک رشته‌ی تصادفی طولانی)
JWT_ACCESS_SECRET=change-this-to-a-long-random-string
JWT_REFRESH_SECRET=change-this-to-another-long-random-string

# مدت اعتبار توکن‌ها (ثانیه)
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000

# دامنه‌ی مجاز برای CORS (دامنه‌ی فرانت‌اند خودتان را بگذارید)
CORS_ORIGIN=https://your-frontend-domain.example

# --- برای فاز دیتابیس واقعی (PostgreSQL) — اختیاری، فعلاً استفاده نمی‌شود ---
# DATABASE_URL=postgres://user:password@host:5432/iron_protocol

# مسیر ذخیره‌سازی پایدار (روی Render/Railway به مسیر دیسک وصل‌شده تنظیم کنید،
# مثلاً /var/data). اگر خالی بماند، از پوشه‌ی کنار پروژه استفاده می‌شود.
# STORAGE_DIR=/var/data

# --- برای اتصال ایمیل واقعی (به‌جای شبیه‌سازی کنسولی) — اختیاری ---
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# --- برای اتصال پیامک واقعی (کاوه‌نگار/ملی‌پیامک) — اختیاری ---
# SMS_API_KEY=
